<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="2026-03-28-01-add-foreign-keys" author="andrew">
        <comment>Add foreign keys for user_id in categories and transactions</comment>

        <!-- Внешний ключ categories -> users -->
        <addForeignKeyConstraint
                baseTableName="categories"
                baseColumnNames="user_id"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_categories_user"
                onDelete="CASCADE"/>

        <!-- Внешний ключ transactions -> users -->
        <addForeignKeyConstraint
                baseTableName="transactions"
                baseColumnNames="user_id"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_transactions_user"
                onDelete="CASCADE"/>

        <!-- Пересоздаём FK для category_id с RESTRICT (чтобы нельзя было удалить категорию с транзакциями) -->
        <dropForeignKeyConstraint
                baseTableName="transactions"
                constraintName="fk_transactions_category"/>

        <addForeignKeyConstraint
                baseTableName="transactions"
                baseColumnNames="category_id"
                referencedTableName="categories"
                referencedColumnNames="id"
                constraintName="fk_transactions_category"
                onDelete="RESTRICT"/>

    </changeSet>
</databaseChangeLog>
